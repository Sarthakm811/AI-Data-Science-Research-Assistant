{
    "framework": "vite",
    "installCommand": "npm --prefix frontend install",
    "buildCommand": "npm --prefix frontend run build",
    "outputDirectory": "frontend/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}